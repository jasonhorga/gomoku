[configuration]

entry_symbol = "gomoku_neural_library_init"
compatibility_minimum = "4.2"

[libraries]

ios.debug = "res://ios/plugins/libgomoku_neural.ios.template_debug.xcframework"
ios.release = "res://ios/plugins/libgomoku_neural.ios.template_release.xcframework"

[dependencies]

ios.debug = {
    "res://ios/plugins/libgodot-cpp.ios.template_debug.xcframework": ""
}
ios.release = {
    "res://ios/plugins/libgodot-cpp.ios.template_release.xcframework": ""
}
